# infra/docker/Dockerfile.ingest
#
# One-shot image that seeds Qdrant (policy documents) and Postgres
# (synthetic market prices). Only runs under the "seed" profile.
#
# Runs:  python scripts/seed_vector_db.py && python scripts/seed_market_prices.py

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    POETRY_VERSION=2.4.1 \
    POETRY_NO_INTERACTION=1 \
    POETRY_VIRTUALENVS_CREATE=false \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir "poetry==${POETRY_VERSION}"

COPY pyproject.toml poetry.lock ./

RUN poetry install --only main --no-root

COPY shared/ ./shared/
COPY services/rag/ ./services/rag/
COPY scripts/ ./scripts/
COPY data/policies/ ./data/policies/

CMD ["sh", "-c", "python scripts/seed_vector_db.py && python scripts/seed_market_prices.py"]
