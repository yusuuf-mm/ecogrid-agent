# EcoGrid-Agent Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

# LLM (required for agent reasoning and RAG constraint parsing)
ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here  # alternative

# LLM model to use for the agent
AGENT_MODEL=claude-sonnet-4-20250514

# LLM model for RAG constraint parsing (uses a smaller/faster model)
RAG_PARSER_MODEL=claude-haiku-4-5-20251001

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# PostgreSQL (market prices + operational state)
POSTGRES_URL=postgresql+asyncpg://ecogrid:ecogrid@localhost:5432/ecogrid

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=grid_policies

# Solver defaults (can be overridden per-request)
BATTERY_CAPACITY_KWH=1000.0
MAX_CHARGE_RATE_KW=250.0
DEFAULT_MIN_BATTERY_BUFFER=0.10

# API
API_HOST=0.0.0.0
API_PORT=8000
