# EcoGrid-Agent Environment Variables
# Copy this to .env and fill in your values. Never commit .env.
# All keys are interpolated by docker-compose.yml — every var here is referenced.

# ─── LLM: OpenAI-compatible gateway (OpenGateway) ───────────────────────────
# The LangChain ChatOpenAI client (used by services/agent and services/rag)
# reads these from the environment automatically — no hardcoded base URL.
# OPENAI_API_KEY: bearer token for the proxy gateway.
# OPENAI_API_BASE: full base URL, including the /v1 suffix. The client
#                  appends the model path; do NOT include a trailing path.
OPENAI_API_KEY=your_key_here
OPENAI_API_BASE=https://opengateway.example.com/v1

# Optional: native OpenAI fallback. Leave OPENAI_API_BASE empty to use
# OpenAI's default. Setting it routes traffic through the gateway.
# OPENAI_API_BASE=

# ─── LLM models ─────────────────────────────────────────────────────────────
# The agent loop (LangChain) uses this for reasoning + tool selection.
AGENT_MODEL=gpt-4o
# The RAG constraint parser uses a smaller/cheaper model for float extraction.
RAG_PARSER_MODEL=gpt-4o-mini

# ─── Redis (Celery broker + result backend + API status cache) ──────────────
# Used by FastAPI for /api/v1/results/{task_id} polling.
REDIS_URL=redis://redis:6379/0
# Celery reads these directly.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── PostgreSQL (market_prices table + operational state) ───────────────────
# POSTGRES_* are the env vars postgres:15-alpine reads to initialise the DB.
POSTGRES_DB=ecogrid
POSTGRES_USER=ecogrid
POSTGRES_PASSWORD=ecogrid
# POSTGRES_URL is the DSN the application (asyncpg / SQLAlchemy) uses.
# In docker-compose it points at the `postgres` service hostname.
POSTGRES_URL=postgresql+asyncpg://ecogrid:ecogrid@postgres:5432/ecogrid
# Used only outside docker (localhost) — docker-compose overrides these.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Qdrant (vector DB for grid_policies) ───────────────────────────────────
# Inside docker this is the qdrant service hostname. Outside: localhost.
QDRANT_URL=http://qdrant:6333
# Collection name for the embedded policy chunks.
QDRANT_COLLECTION=grid_policies

# ─── Solver defaults (overridable per-request via OptimizationRequest) ──────
# Total battery capacity in kWh.
BATTERY_CAPACITY_KWH=1000.0
# Max charge/discharge rate in kW. Also the bound on simultaneous
# charge + discharge (c[t] + d[t] <= MAX_CHARGE_RATE_KW).
MAX_CHARGE_RATE_KW=250.0
# Fallback SoC buffer fraction (0.0–1.0) when RAG returns no policy.
# The agent overrides this with the value parsed from a retrieved policy.
DEFAULT_MIN_BATTERY_BUFFER=0.10

# ─── Seed script tunables ───────────────────────────────────────────────────
# Number of days of synthetic market prices to generate.
SEED_DAYS=90
# ERCOT pricing node used for synthetic data.
SEED_NODE_ID=ERCOT_HOUSTON

# ─── API ────────────────────────────────────────────────────────────────────
# uvicorn bind interface (inside container, 0.0.0.0 is required).
API_HOST=0.0.0.0
API_PORT=8000
