# ──────────────────────────────────────────────────────────────────────────────
# EcoGrid-Agent Environment Variables (Refactored for Gemini SDK Layer)
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM: Google Gemini AI Configuration ──────────────────────────────────────
# The direct Gemini SDK reads GEMINI_API_KEY from the environment automatically.
GEMINI_API_KEY="api-key"
GEMINI_MODEL=gemini-2.5-flash

# ─── Redis (Celery broker + result backend + API status cache) ────────────────
# Internal container routing for the Codespace Docker network
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── PostgreSQL (market_prices table + operational state) ─────────────────────
POSTGRES_DB=ecogrid
POSTGRES_USER=ecogrid
POSTGRES_PASSWORD=ecogrid
# Points cleanly at the 'postgres' service hostname inside the compose stack
POSTGRES_URL=postgresql+asyncpg://ecogrid:ecogrid@postgres:5432/ecogrid
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Qdrant (vector DB for grid_policies) ─────────────────────────────────────
# Points cleanly at the 'qdrant' service hostname inside the compose stack
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=grid_policies

# ─── Solver defaults (overridable per-request via OptimizationRequest) ────────
BATTERY_CAPACITY_KWH=1000.0
MAX_CHARGE_RATE_KW=250.0
DEFAULT_MIN_BATTERY_BUFFER=0.10

# ─── Seed script tunables ─────────────────────────────────────────────────────
SEED_DAYS=90
SEED_NODE_ID=ERCOT_HOUSTON

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000